// Prisma 7 schema
// - Uses the new ESM-first "prisma-client" generator
// - Output goes to ../generated/prisma so imports are clean and explicit
// - No url/directUrl here – managed entirely in prisma.config.ts

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
//  Enums
// ─────────────────────────────────────────────

enum UserRole {
  USER
  MODERATOR
  CONTENT_ADMIN
  SUPER_ADMIN
}

enum EventType {
  Workshop
  Hackathon
  Meetup
}

enum EventStatus {
  Upcoming
  Live
  Past
}

enum RegistrationStatus {
  Registered
  Attended
  Cancelled
}

enum ProjectStatus {
  Pending
  Approved
  Rejected
}

enum BlogStatus {
  Draft
  Published
}

enum ResourceType {
  Video
  PDF
  Tool
  Cheatsheet
}

enum ResourceStatus {
  Approved
  Pending
}

enum RoadmapCategory {
  Web
  DataScience
  CP
}

enum ContactStatus {
  Open
  Resolved
}

enum TestimonialStatus {
  Approved
  Pending
}

// ─────────────────────────────────────────────
//  Core User
// ─────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  prn         String   @unique
  name        String
  email       String   @unique
  password    String
  role        UserRole @default(USER)
  avatar      String?
  xp          Int      @default(0)
  level       Int      @default(1)
  circuit     Int      @default(0)
  global_rank Int?
  is_verified Boolean  @default(false)
  created_at  DateTime @default(now())

  admin                     Admin?
  event_registrations       EventRegistration[]
  created_projects          Project[]                @relation("ProjectCreator")
  project_memberships       ProjectMember[]
  blogs                     Blog[]
  resources                 Resource[]
  user_achievements         UserAchievement[]
  certificates              Certificate[]
  testimonials              Testimonial[]
  contact_messages          ContactMessage[]
  email_verification_tokens EmailVerificationToken[]
  password_reset_tokens     PasswordResetToken[]

  @@map("users")
}

// ─────────────────────────────────────────────
//  Admin (granular permission flags per role)
// ─────────────────────────────────────────────

model Admin {
  id                      String  @id @default(cuid())
  user_id                 String  @unique
  can_manage_events       Boolean @default(false)
  can_manage_projects     Boolean @default(false)
  can_manage_blogs        Boolean @default(false)
  can_manage_resources    Boolean @default(false)
  can_manage_users        Boolean @default(false)
  can_manage_achievements Boolean @default(false)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("admins")
}

// ─────────────────────────────────────────────
//  Email & Password Tokens
// ─────────────────────────────────────────────

model EmailVerificationToken {
  id         String   @id @default(cuid())
  user_id    String
  token      String   @unique
  expires_at DateTime
  is_used    Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  user_id    String
  token      String   @unique
  expires_at DateTime
  is_used    Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────
//  Events
// ─────────────────────────────────────────────

model Event {
  id               String      @id @default(cuid())
  name             String
  title            String
  description      String?
  type             EventType
  status           EventStatus @default(Upcoming)
  location         String?
  start_date       DateTime
  end_date         DateTime?
  max_participants Int?
  banner_image     String?
  created_by       String

  registrations EventRegistration[]
  certificates  Certificate[]

  @@map("events")
}

model EventRegistration {
  id            String             @id @default(cuid())
  user_id       String
  event_id      String
  status        RegistrationStatus @default(Registered)
  registered_at DateTime           @default(now())

  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  event Event @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@unique([user_id, event_id])
  @@map("event_registrations")
}

// ─────────────────────────────────────────────
//  Projects
// ─────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  title       String
  description String?
  image       String?
  repo_link   String?
  demo_link   String?
  video_link  String?
  status      ProjectStatus @default(Pending)
  created_by  String
  created_at  DateTime      @default(now())

  creator User            @relation("ProjectCreator", fields: [created_by], references: [id])
  members ProjectMember[]

  @@map("projects")
}

model ProjectMember {
  id         String @id @default(cuid())
  project_id String
  user_id    String

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([project_id, user_id])
  @@map("project_members")
}

// ─────────────────────────────────────────────
//  Blogs
// ─────────────────────────────────────────────

model Blog {
  id          String     @id @default(cuid())
  title       String
  content     String
  cover_image String?
  status      BlogStatus @default(Draft)
  author_id   String
  created_at  DateTime   @default(now())

  author User @relation(fields: [author_id], references: [id], onDelete: Cascade)

  @@map("blogs")
}

// ─────────────────────────────────────────────
//  Resources
// ─────────────────────────────────────────────

model Resource {
  id          String         @id @default(cuid())
  title       String
  type        ResourceType
  link        String
  uploaded_by String
  status      ResourceStatus @default(Pending)
  created_at  DateTime       @default(now())

  uploader User @relation(fields: [uploaded_by], references: [id], onDelete: Cascade)

  @@map("resources")
}

// ─────────────────────────────────────────────
//  Roadmaps
// ─────────────────────────────────────────────

model Roadmap {
  id          String          @id @default(cuid())
  title       String
  description String?
  category    RoadmapCategory
  created_by  String

  nodes RoadmapNode[]

  @@map("roadmaps")
}

model RoadmapNode {
  id             String  @id @default(cuid())
  roadmap_id     String
  title          String
  description    String?
  resource_link  String?
  sequence_order Int

  roadmap Roadmap @relation(fields: [roadmap_id], references: [id], onDelete: Cascade)

  @@map("roadmap_nodes")
}

// ─────────────────────────────────────────────
//  Achievements & XP
// ─────────────────────────────────────────────

model Achievement {
  id          String  @id @default(cuid())
  title       String
  description String?
  badge_image String?
  xp_reward   Int     @default(0)

  user_achievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id             String   @id @default(cuid())
  user_id        String
  achievement_id String
  earned_at      DateTime @default(now())

  user        User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievement_id], references: [id], onDelete: Cascade)

  @@unique([user_id, achievement_id])
  @@map("user_achievements")
}

// ─────────────────────────────────────────────
//  Certificates
// ─────────────────────────────────────────────

model Certificate {
  id              String   @id @default(cuid())
  user_id         String
  event_id        String
  certificate_url String
  issued_at       DateTime @default(now())

  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  event Event @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@map("certificates")
}

// ─────────────────────────────────────────────
//  Testimonials
// ─────────────────────────────────────────────

model Testimonial {
  id          String            @id @default(cuid())
  user_id     String
  event_id    String
  quote       String
  company     String?
  designation String?
  status      TestimonialStatus @default(Pending)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("testimonials")
}

// ─────────────────────────────────────────────
//  Contact Messages
// ─────────────────────────────────────────────

model ContactMessage {
  id         String        @id @default(cuid())
  name       String
  email      String
  message    String
  status     ContactStatus @default(Open)
  user_id    String?
  created_at DateTime      @default(now())

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@map("contact_messages")
}
